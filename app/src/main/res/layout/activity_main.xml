<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/kb_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setup_title"
            android:textColor="@color/key_text"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/setup_intro"
            android:textColor="@color/key_text_dim"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/statusEnabled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:textColor="@color/key_text"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btnEnable"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/btn_enable" />

        <TextView
            android:id="@+id/statusActive"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="@color/key_text"
            android:textSize="15sp" />

        <Button
            android:id="@+id/btnSelect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/btn_select" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="20dp"
            android:background="@color/key_border" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textColor="@color/key_text"
            android:textSize="20sp"
            android:textStyle="bold" />

        <CheckBox
            android:id="@+id/cbHaptics"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:buttonTint="@color/accent"
            android:text="@string/pref_haptics"
            android:textColor="@color/key_text" />

        <CheckBox
            android:id="@+id/cbSound"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:buttonTint="@color/accent"
            android:text="@string/pref_sound"
            android:textColor="@color/key_text" />

        <CheckBox
            android:id="@+id/cbPopup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:buttonTint="@color/accent"
            android:text="@string/pref_popup"
            android:textColor="@color/key_text" />

        <TextView
            android:id="@+id/lblKeyHeight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/pref_key_height"
            android:textColor="@color/key_text"
            android:textSize="14sp" />

        <SeekBar
            android:id="@+id/seekKeyHeight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/lblRepeatInterval"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/pref_repeat_interval"
            android:textColor="@color/key_text"
            android:textSize="14sp" />

        <SeekBar
            android:id="@+id/seekRepeatInterval"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/try_it"
            android:textColor="@color/key_text_dim"
            android:textSize="14sp" />

        <EditText
            android:id="@+id/tryInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@color/key_normal"
            android:hint="Type / test Ctrl, arrows, Esc here"
            android:inputType="textMultiLine"
            android:minLines="3"
            android:padding="12dp"
            android:textColor="@color/key_text"
            android:textColorHint="@color/key_text_dim" />

    </LinearLayout>
</ScrollView>
